{
    "namespace": "Audio",

    "bridge_functions": [
        {
            "name": "Audio.load",
            "android": "com.narraid.audio.AudioFunctions.Load",
            "ios": "AudioFunctions.Load",
            "description": "Load an audio file without starting playback. Use resume() to start playing."
        },
        {
            "name": "Audio.play",
            "android": "com.narraid.audio.AudioFunctions.Play",
            "ios": "AudioFunctions.Play",
            "description": "Play an audio file from a URL or local path"
        },
        {
            "name": "Audio.pause",
            "android": "com.narraid.audio.AudioFunctions.Pause",
            "ios": "AudioFunctions.Pause",
            "description": "Pause the current audio playback"
        },
        {
            "name": "Audio.resume",
            "android": "com.narraid.audio.AudioFunctions.Resume",
            "ios": "AudioFunctions.Resume",
            "description": "Resume the paused audio playback"
        },
        {
            "name": "Audio.stop",
            "android": "com.narraid.audio.AudioFunctions.Stop",
            "ios": "AudioFunctions.Stop",
            "description": "Stop the audio playback and reset the position"
        },
        {
            "name": "Audio.seek",
            "android": "com.narraid.audio.AudioFunctions.Seek",
            "ios": "AudioFunctions.Seek",
            "description": "Seek to a specific position in the audio (in seconds)"
        },
        {
            "name": "Audio.setVolume",
            "android": "com.narraid.audio.AudioFunctions.SetVolume",
            "ios": "AudioFunctions.SetVolume",
            "description": "Set the audio volume (0.0 to 1.0)"
        },
        {
            "name": "Audio.getDuration",
            "android": "com.narraid.audio.AudioFunctions.GetDuration",
            "ios": "AudioFunctions.GetDuration",
            "description": "Get the duration of the current audio in seconds"
        },
        {
            "name": "Audio.getCurrentPosition",
            "android": "com.narraid.audio.AudioFunctions.GetCurrentPosition",
            "ios": "AudioFunctions.GetCurrentPosition",
            "description": "Get the current playback position in seconds"
        },
        {
            "name": "Audio.getState",
            "android": "com.narraid.audio.AudioFunctions.GetState",
            "ios": "AudioFunctions.GetState",
            "description": "Get the full current playback state (url, position, duration, isPlaying, metadata) from the native audio layer"
        },
        {
            "name": "Audio.setMetadata",
            "android": "com.narraid.audio.AudioFunctions.SetMetadata",
            "ios": "AudioFunctions.SetMetadata",
            "description": "Set track metadata (title, artist, album, artwork, duration) for lock screens, Bluetooth devices, and OS media centers"
        },
        {
            "name": "Audio.drainEvents",
            "android": "com.narraid.audio.AudioFunctions.DrainEvents",
            "ios": "AudioFunctions.DrainEvents",
            "description": "Return and clear all events queued while the app was in the background"
        },
        {
            "name": "Audio.setPlaylist",
            "android": "com.narraid.audio.AudioFunctions.SetPlaylist",
            "ios": "AudioFunctions.SetPlaylist",
            "description": "Set the playlist queue natively so tracks auto-advance in the background"
        },
        {
            "name": "Audio.nextTrack",
            "android": "com.narraid.audio.AudioFunctions.NextTrack",
            "ios": "AudioFunctions.NextTrack",
            "description": "Skip to the next track in the active playlist"
        },
        {
            "name": "Audio.previousTrack",
            "android": "com.narraid.audio.AudioFunctions.PreviousTrack",
            "ios": "AudioFunctions.PreviousTrack",
            "description": "Skip to the previous track in the active playlist"
        },
        {
            "name": "Audio.getPlaylist",
            "android": "com.narraid.audio.AudioFunctions.GetPlaylist",
            "ios": "AudioFunctions.GetPlaylist",
            "description": "Get the current playlist state (items, index, total, repeatMode, shuffleMode)"
        },
        {
            "name": "Audio.setRepeatMode",
            "android": "com.narraid.audio.AudioFunctions.SetRepeatMode",
            "ios": "AudioFunctions.SetRepeatMode",
            "description": "Set the repeat mode: none, one (repeat current track), all (repeat playlist)"
        },
        {
            "name": "Audio.setShuffleMode",
            "android": "com.narraid.audio.AudioFunctions.SetShuffleMode",
            "ios": "AudioFunctions.SetShuffleMode",
            "description": "Enable or disable shuffle mode for the active playlist"
        }
    ],

    "android": {
        "min_version": 21,
        "permissions": [
            "android.permission.INTERNET",
            "android.permission.MEDIA_CONTENT_CONTROL",
            "android.permission.FOREGROUND_SERVICE",
            "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
            "android.permission.WAKE_LOCK"
        ],
        "dependencies": {
            "implementation": [
                "androidx.media:media:1.7.0",
                "androidx.core:core-ktx:1.13.1"
            ]
        },
        "activities": [],
        "services": [
            {
                "name": "com.narraid.audio.AudioService",
                "foregroundServiceType": "mediaPlayback",
                "exported": false
            }
        ],
        "receivers": [],
        "providers": []
    },

    "ios": {
        "min_version": "13.0",
        "init_function": "AudioFunctions.setupAudioSession",
        "background_modes": ["audio"],
        "info_plist": {
            "NSAppleMusicUsageDescription": "We need access to your music library to play audio files."
        },
        "dependencies": {
            "swift_packages": [],
            "pods": []
        }
    },

    "events": [
        "Narraid\\Audio\\Events\\PlaybackLoaded",
        "Narraid\\Audio\\Events\\PlaybackStarted",
        "Narraid\\Audio\\Events\\PlaybackPaused",
        "Narraid\\Audio\\Events\\PlaybackResumed",
        "Narraid\\Audio\\Events\\PlaybackStopped",
        "Narraid\\Audio\\Events\\PlaybackCompleted",
        "Narraid\\Audio\\Events\\PlaybackSeeked",
        "Narraid\\Audio\\Events\\PlaybackFailed",
        "Narraid\\Audio\\Events\\PlaybackProgressUpdated",
        "Narraid\\Audio\\Events\\RemotePlayReceived",
        "Narraid\\Audio\\Events\\RemotePauseReceived",
        "Narraid\\Audio\\Events\\RemoteNextTrackReceived",
        "Narraid\\Audio\\Events\\RemotePreviousTrackReceived",
        "Narraid\\Audio\\Events\\RemoteSeekReceived",
        "Narraid\\Audio\\Events\\RemoteStopReceived",
        "Narraid\\Audio\\Events\\AudioFocusLost",
        "Narraid\\Audio\\Events\\AudioFocusLostTransient",
        "Narraid\\Audio\\Events\\AudioFocusDucked",
        "Narraid\\Audio\\Events\\AudioFocusGained",
        "Narraid\\Audio\\Events\\PlaylistSet",
        "Narraid\\Audio\\Events\\PlaylistTrackChanged",
        "Narraid\\Audio\\Events\\PlaylistEnded"
    ],

    "hooks": {}
}
