{
    "name": "narraid/nativephp-audio",
    "description": "Audio player plugin for NativePHP",
    "version": "4.10.0",
    "type": "nativephp-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "nativephp/mobile": "^3.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Narraid\\Audio\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Narraid\\Audio\\AudioServiceProvider"
            ],
            "aliases": {
                "Audio": "Narraid\\Audio\\Facades\\Audio"
            }
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    }
}