// Added Native.call() method to JavaScript helper:
const Native = {
    on: (event, callback) => { /* existing code */ },
    call: async (functionName, params = {}) => {
        return new Promise((resolve, reject) => {
            const callId = 'call_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);

            const timeoutId = setTimeout(() => {
                window.removeEventListener(callId, handler);
                reject(new Error('Native call timeout'));
            }, 10000);

            const handler = (event) => {
                clearTimeout(timeoutId);
                window.removeEventListener(callId, handler);
                if (event.detail.error) {
                    reject(new Error(event.detail.error));
                } else {
                    resolve(event.detail.result);
                }
            };

            window.addEventListener(callId, handler);
            window.webkit.messageHandlers.nativeCall.postMessage({
                callId: callId,
                function: functionName,
                params: params
            });
        });
    }
};

// Added NativeCallHandler class at the end of the file:
class NativeCallHandler: NSObject, WKScriptMessageHandler {
    weak var webView: WKWebView?

    func userContentController(_ userContentController: WKUserContentController, didReceive message: WKScriptMessage) {
        guard let body = message.body as? [String: Any],
              let callId = body["callId"] as? String,
              let functionName = body["function"] as? String else {
            return
        }

        let params = body["params"] as? [String: Any] ?? [:]

        // Convert params to JSON and call NativePHPCall
        guard let jsonData = try? JSONSerialization.data(withJSONObject: params, options: []),
              let jsonString = String(data: jsonData, encoding: .utf8) else {
            sendResponse(callId: callId, error: "Failed to serialize parameters")
            return
        }

        let resultJson = NativePHPCall(functionName, jsonString)
        let resultString = String(cString: resultJson!)

        // Parse and send result back to JavaScript
        guard let resultData = resultString.data(using: .utf8),
              let result = try? JSONSerialization.jsonObject(with: resultData, options: []) as? [String: Any] else {
            sendResponse(callId: callId, error: "Failed to parse result")
            return
        }

        if let error = result["error"] as? String {
            sendResponse(callId: callId, error: error)
        } else {
            sendResponse(callId: callId, result: result)
        }
    }

    private func sendResponse(callId: String, result: [String: Any]? = nil, error: String? = nil) {
        // Sends custom event back to JavaScript with result
    }
}

