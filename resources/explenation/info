import Foundation
import AVFoundation
import MediaPlayer

// MARK: - Audio Player Manager

class AudioPlayerManager {
    static let shared = AudioPlayerManager()

    private var player: AVPlayer?
    private var timeObserver: Any?

    private init() {
        setupRemoteCommands()
    }

    func load(url: URL, title: String, artist: String, artwork: String?) {
        // Remove existing time observer
        if let observer = timeObserver {
            player?.removeTimeObserver(observer)
            timeObserver = nil
        }

        // Create player
        let playerItem = AVPlayerItem(url: url)
        player = AVPlayer(playerItem: playerItem)

        // Setup Now Playing metadata
        setupNowPlaying(title: title, artist: artist, artwork: artwork, duration: getDuration())

        // Add time observer for progress updates
        let interval = CMTime(seconds: 1.0, preferredTimescale: CMTimeScale(NSEC_PER_SEC))
        timeObserver = player?.addPeriodicTimeObserver(forInterval: interval, queue: .main) { [weak self] time in
            guard let self = self else { return }
            let currentTime = CMTimeGetSeconds(time)
            let duration = self.getDuration()

            // Send progress update to JavaScript
            LaravelBridge.shared.send?("Native\\Mobile\\Events\\AudioPlayer\\TimeUpdate", [
                "currentTime": currentTime,
                "duration": duration
            ])

            // Update Now Playing elapsed time
            self.updateNowPlayingTime(currentTime)
        }

        // Observe playback end
        NotificationCenter.default.addObserver(
            forName: .AVPlayerItemDidPlayToEndTime,
            object: playerItem,
            queue: .main
        ) { [weak self] _ in
            self?.updateNowPlayingState(isPlaying: false)
            LaravelBridge.shared.send?("Native\\Mobile\\Events\\AudioPlayer\\Ended", [:])
        }

        print("📱 Audio loaded: \(url)")
    }

    func play() {
        player?.play()
        updateNowPlayingState(isPlaying: true)
        print("📱 Audio playing")
    }

    func pause() {
        player?.pause()
        updateNowPlayingState(isPlaying: false)
        print("📱 Audio paused")
    }

    func seek(to time: Double) {
        let cmTime = CMTime(seconds: time, preferredTimescale: CMTimeScale(NSEC_PER_SEC))
        player?.seek(to: cmTime)
        updateNowPlayingTime(time)
        print("📱 Audio seeked to: \(time)")
    }

    func getCurrentTime() -> Double {
        guard let player = player else { return 0 }
        return CMTimeGetSeconds(player.currentTime())
    }

    func getDuration() -> Double {
        guard let player = player,
              let duration = player.currentItem?.duration else { return 0 }
        let seconds = CMTimeGetSeconds(duration)
        return seconds.isNaN ? 0 : seconds
    }

    func isPlaying() -> Bool {
        return player?.rate != 0 && player?.error == nil
    }

    // MARK: - Now Playing Integration

    private func setupNowPlaying(title: String, artist: String, artwork: String?, duration: Double) {
        var nowPlayingInfo: [String: Any] = [
            MPMediaItemPropertyTitle: title,
            MPMediaItemPropertyArtist: artist,
            MPMediaItemPropertyPlaybackDuration: duration,
            MPNowPlayingInfoPropertyPlaybackRate: 0.0,
            MPNowPlayingInfoPropertyElapsedPlaybackTime: 0.0
        ]

        MPNowPlayingInfoCenter.default().nowPlayingInfo = nowPlayingInfo
        print("📱 Now Playing info set: \(title) by \(artist)")

        // Load artwork asynchronously
        if let artworkString = artwork {
            loadArtwork(from: artworkString) { artwork in
                if let artwork = artwork {
                    var updatedInfo = MPNowPlayingInfoCenter.default().nowPlayingInfo ?? nowPlayingInfo
                    updatedInfo[MPMediaItemPropertyArtwork] = artwork
                    MPNowPlayingInfoCenter.default().nowPlayingInfo = updatedInfo
                    print("📱 Artwork loaded and set")
                }
            }
        }
    }

    private func updateNowPlayingState(isPlaying: Bool) {
        DispatchQueue.main.async {
            if var currentInfo = MPNowPlayingInfoCenter.default().nowPlayingInfo {
                currentInfo[MPNowPlayingInfoPropertyPlaybackRate] = isPlaying ? 1.0 : 0.0
                currentInfo[MPNowPlayingInfoPropertyElapsedPlaybackTime] = self.getCurrentTime()
                MPNowPlayingInfoCenter.default().nowPlayingInfo = currentInfo
            }
        }
    }

    private func updateNowPlayingTime(_ time: Double) {
        DispatchQueue.main.async {
            if var currentInfo = MPNowPlayingInfoCenter.default().nowPlayingInfo {
                currentInfo[MPNowPlayingInfoPropertyElapsedPlaybackTime] = time
                MPNowPlayingInfoCenter.default().nowPlayingInfo = currentInfo
            }
        }
    }

    private func loadArtwork(from string: String, completion: @escaping (MPMediaItemArtwork?) -> Void) {
        if let url = URL(string: string), string.hasPrefix("http") {
            DispatchQueue.global(qos: .userInitiated).async {
                if let data = try? Data(contentsOf: url),
                   let image = UIImage(data: data) {
                    let artwork = MPMediaItemArtwork(boundsSize: image.size) { _ in image }
                    DispatchQueue.main.async {
                        completion(artwork)
                    }
                } else {
                    DispatchQueue.main.async {
                        completion(nil)
                    }
                }
            }
        } else if let data = Data(base64Encoded: string),
                  let image = UIImage(data: data) {
            let artwork = MPMediaItemArtwork(boundsSize: image.size) { _ in image }
            completion(artwork)
        } else {
            completion(nil)
        }
    }

    private func setupRemoteCommands() {
        let commandCenter = MPRemoteCommandCenter.shared()

        commandCenter.playCommand.isEnabled = true
        commandCenter.playCommand.addTarget { [weak self] _ in
            self?.play()
            return .success
        }

        commandCenter.pauseCommand.isEnabled = true
        commandCenter.pauseCommand.addTarget { [weak self] _ in
            self?.pause()
            return .success
        }

        commandCenter.nextTrackCommand.isEnabled = true
        commandCenter.nextTrackCommand.addTarget { [weak self] _ in
            guard let self = self else { return .commandFailed }
            let newTime = min(self.getCurrentTime() + 10, self.getDuration())
            self.seek(to: newTime)
            return .success
        }

        commandCenter.previousTrackCommand.isEnabled = true
        commandCenter.previousTrackCommand.addTarget { [weak self] _ in
            guard let self = self else { return .commandFailed }
            let newTime = max(self.getCurrentTime() - 10, 0)
            self.seek(to: newTime)
            return .success
        }

        print("📱 Remote commands configured")
    }
}

// MARK: - Audio Player Bridge Functions

enum AudioPlayerFunctions {

    /// Load audio with metadata
    class Load: BridgeFunction {
        func execute(parameters: [String: Any]) throws -> [String: Any] {
            guard let urlString = parameters["url"] as? String,
                  let url = URL(string: urlString) else {
                throw BridgeError.invalidParameters("url is required")
            }

            let title = parameters["title"] as? String ?? "Unknown Track"
            let artist = parameters["artist"] as? String ?? "Unknown Artist"
            let artwork = parameters["artwork"] as? String

            AudioPlayerManager.shared.load(url: url, title: title, artist: artist, artwork: artwork)

            return [
                "success": true,
                "duration": AudioPlayerManager.shared.getDuration()
            ]
        }
    }

    /// Play audio
    class Play: BridgeFunction {
        func execute(parameters: [String: Any]) throws -> [String: Any] {
            AudioPlayerManager.shared.play()
            return ["success": true]
        }
    }

    /// Pause audio
    class Pause: BridgeFunction {
        func execute(parameters: [String: Any]) throws -> [String: Any] {
            AudioPlayerManager.shared.pause()
            return ["success": true]
        }
    }

    /// Seek to time
    class Seek: BridgeFunction {
        func execute(parameters: [String: Any]) throws -> [String: Any] {
            guard let time = parameters["time"] as? Double else {
                throw BridgeError.invalidParameters("time is required")
            }
            AudioPlayerManager.shared.seek(to: time)
            return ["success": true]
        }
    }

    /// Get player state
    class GetState: BridgeFunction {
        func execute(parameters: [String: Any]) throws -> [String: Any] {
            return [
                "success": true,
                "currentTime": AudioPlayerManager.shared.getCurrentTime(),
                "duration": AudioPlayerManager.shared.getDuration(),
                "isPlaying": AudioPlayerManager.shared.isPlaying()
            ]
        }
    }
}


